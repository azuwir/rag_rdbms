DATABASE_URL="postgresql://postgres:password@localhost:5432/rag_rdbms?schema=public"

# Auth (NextAuth/Auth.js)
# Generate: `openssl rand -base64 32`
AUTH_SECRET="isi_secret_random_di_sini"

# SUMOPOD (OpenAI-compatible)
# Base URL yang dipakai SDK umumnya: https://ai.sumopod.com/v1
# (Endpoint chat: /v1/chat/completions)
SUMOPOD_API_KEY="isi_api_key_sumopod_di_sini"
SUMOPOD_BASE_URL="https://ai.sumopod.com/v1"
SUMOPOD_MODEL="gpt-4o-mini"

# (Opsional) DWIPA (OpenAI-compatible)
# DWIPA_API_KEY="isi_api_key_dwipa_di_sini"
# DWIPA_BASE_URL="https://ai.dwipa.my.id/v1"
# DWIPA_MODEL="gpt-4o-mini"

# (Opsional) Kalau mau pakai variabel OpenAI generik:
# OPENAI_API_KEY="isi_api_key_di_sini"
# OPENAI_BASE_URL="https://ai.sumopod.com/v1"
# OPENAI_MODEL="gpt-4o-mini"
